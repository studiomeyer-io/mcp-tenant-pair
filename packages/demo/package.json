{
  "name": "mcp-tenant-pair-demo",
  "version": "0.1.0",
  "description": "Reference MCP server demonstrating mcp-tenant-pair (12 tools, stdio): pair lifecycle + bi-temporal shared state + DSGVO Art.17 erasure",
  "license": "MIT",
  "author": "Matthias Meyer (StudioMeyer)",
  "type": "module",
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "bin": {
