{
  "name": "mcp-tenant-pair",
  "version": "0.1.1",
  "description": "Foundation library for multi-user tenancy in MCP servers (pairs, groups, shared state, bi-temporal conflicts)",
  "license": "MIT",
  "author": "Matthias Meyer (StudioMeyer)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./store/sqlite": {
      "types": "./dist/store/sqlite.d.ts",
      "import": "./dist/store/sqlite.js"
    },
    "./store/postgres": {
      "types": "./dist/store/postgres.d.ts",
      "import": "./dist/store/postgres.js"
    },
    "./resolvers/lww": {
      "types": "./dist/resolvers/lww.d.ts",
      "import": "./dist/resolvers/lww.js"
    },
    "./resolvers/manual": {
      "types": "./dist/resolvers/manual.d.ts",
      "import": "./dist/resolvers/manual.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "multi-tenant",
    "couple",
    "shared-state",
    "bi-temporal"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "rimraf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "better-sqlite3": "^12.0.0",
    "uuid": "^14.0.0",
    "zod": "^3.23.8"
  },
  "peerDependencies": {
    "pg": "^8.20.0"
  },
  "peerDependenciesMeta": {
    "pg": {
      "optional": true
    }
  },
  "devDependencies": {
    "pg": "^8.20.0"
  }
}
