{
  "name": "mcp-tenant-pair-monorepo",
  "version": "0.1.1",
  "private": true,
  "description": "Foundation library + reference MCP server for multi-user tenancy in consumer MCP servers",
  "license": "MIT",
  "author": "Matthias Meyer (StudioMeyer)",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/lib",
    "packages/cli",
    "packages/demo"
  ],
  "scripts": {
    "build": "tsc -b packages/lib packages/cli packages/demo",
    "test": "vitest run",
    "typecheck": "tsc -b --pretty packages/lib packages/cli packages/demo",
    "clean": "rimraf packages/*/dist packages/*/tsconfig.tsbuildinfo"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.7.0",
    "@types/pg": "^8.11.10",
    "@types/uuid": "^10.0.0",
    "rimraf": "^6.0.1",
    "typescript": "^6.0.3",
    "vitest": "^2.1.4"
  }
}
